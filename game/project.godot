; Engine configuration file.
; Godot 4 project file for the first playable PC demo.

config_version=5

[application]

config/name="Da Luang Dou"
config/description="Steam/PC endless 2D auto-battle demo."
run/main_scene="res://scenes/app/Main.tscn"
config/features=PackedStringArray("4.0")
config/icon="res://icon.svg"

[autoload]

ConfigDb="*res://scripts/autoload/config_db.gd"
SaveManager="*res://scripts/autoload/save_manager.gd"
GameTime="*res://scripts/autoload/game_time.gd"
RunState="*res://scripts/autoload/run_state.gd"
DebugLaunch="*res://scripts/autoload/debug_launch.gd"
I18nText="*res://scripts/autoload/i18n_text.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/size/mode=0
window/size/resizable=true
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"

[input]

